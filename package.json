{
  "name": "@dodlhuat/basix",
  "version": "1.4.2",
  "description": "Basix is intended as a starter for the rapid development of a design. Each design element can be added individually to include only the data required. It is using plain javascript / typescript and therefore is not dependent on any plugin.",
  "exports": {
    "./css/*": "./css/*",
    "./js/*": "./js/*",
    "./svg-icons/*": "./svg-icons/*"
  },
  "files": [
    "js/",
    "css/",
    "fonts/",
    "svg-icons/"
  ],
  "keywords": [
    "ui",
    "components",
    "css",
    "typescript",
    "design-system",
    "starter"
  ],
  "author": "Andi Bauer",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dodlhuat/basix.git"
  },
  "bugs": {
    "url": "https://github.com/dodlhuat/basix/issues"
  },
  "homepage": "https://github.com/dodlhuat/basix#readme",
  "devDependencies": {
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.61.0"
  }
}
